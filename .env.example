# Copy this file to .env.local and fill in real values.
# Supabase project values come from the dashboard at Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only (not exposed to the browser). Required to register a staff
# account at /sign-up. Rotate periodically; share out-of-band.
STAFF_INVITE_CODE=replace-with-a-shared-secret
